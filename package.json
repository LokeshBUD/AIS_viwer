{
  "name": "ais-maritime-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev": "concurrently -n SERVER,CLIENT -c cyan,yellow \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "preview": "vite preview",
    "predeploy": "node scripts/sync-backend-url.mjs && npm run build",
    "deploy": "gh-pages -d dist/client"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "leaflet": "^1.9.4",
    "searoute-ts": "^2.2.0",
    "three": "^0.168.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.0.0",
    "@types/three": "^0.168.0",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "gh-pages": "^6.2.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
